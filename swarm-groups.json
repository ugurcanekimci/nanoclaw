{
  "_comment": "NanoClaw group registration config for the swarm. Use this as a reference when registering groups via the main agent. Slack channel IDs must be filled in after creating the channels.",

  "groups": [
    {
      "name": "Swarm Main",
      "folder": "slack_swarm-main",
      "trigger": "@Swarm",
      "isMain": true,
      "requiresTrigger": false,
      "containerConfig": {
        "additionalMounts": [
          {
            "hostPath": "/Users/u/Documents/swarm-kb",
            "containerPath": "swarm-kb",
            "readonly": true
          },
          {
            "hostPath": "/Users/u/swarm",
            "containerPath": "swarm-project",
            "readonly": true
          }
        ]
      }
    },
