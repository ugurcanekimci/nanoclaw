# NanoClaw Environment Variables

# --- Langfuse Observability ---
# Master kill switch (default: false)
# LANGFUSE_ENABLED=true
# Langfuse project keys
# LANGFUSE_PUBLIC_KEY=pk-lf-...
# LANGFUSE_SECRET_KEY=sk-lf-...
# Langfuse API endpoint (default: https://cloud.langfuse.com)
# LANGFUSE_BASEURL=http://localhost:3000
# Trace sampling rate 0.0–1.0 (default: 1.0, decided per-trace)
# LANGFUSE_SAMPLE_RATE=1.0
# Capture prompt text in traces — increases storage (default: false)
# LANGFUSE_CAPTURE_PROMPTS=false
# Capture MCP tool inputs/outputs in traces — increases storage (default: false)
# LANGFUSE_CAPTURE_TOOL_IO=false
