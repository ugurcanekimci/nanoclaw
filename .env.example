# Anthropic API key (required if not using OAuth)
ANTHROPIC_API_KEY=

# OpenAI API key (optional — enables SWARM_MODEL=gpt-4o and other OpenAI models in containers)
OPENAI_API_KEY=

# GitHub PAT (optional — passed only to GITHUB_TOKEN_ALLOWED_GROUPS containers, e.g. slack_swarm-coder)
GITHUB_TOKEN=

# Slack credentials (required if using Slack channel)
SLACK_BOT_TOKEN=
SLACK_APP_TOKEN=
